 
# ================================
# CareerPath AI — .gitignore
# MERN Stack (React + Node/Express + MongoDB)
# ================================

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Environment Variables (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Keep the example file (safe to commit)
!.env.example

# ─── React / Frontend Build ───────────────────────────────────────────────────
frontend/build/
frontend/.cache/

# ─── Backend Logs ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Runtime & Process ────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Optional / Misc ──────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.parcel-cache/
dist/
tmp/
temp/

# ─── MongoDB local data (if running locally via Docker or direct) ─────────────
data/db/
mongo-data/

# ─── Docker ───────────────────────────────────────────────────────────────────
.dockerignore

# ─── Uploads / User content ───────────────────────────────────────────────────
uploads/
public/uploads/
